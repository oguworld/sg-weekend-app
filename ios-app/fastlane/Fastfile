require 'base64'
require 'tmpdir'

default_platform(:ios)

platform :ios do
  desc "Build and upload to App Store"
  lane :deploy do
    setup_ci if ENV['CI']

    cert_path = File.join(Dir.tmpdir, "dist.p12")
    File.binwrite(cert_path, Base64.decode64(ENV['DIST_CERT_BASE64']))
    import_certificate(
      certificate_path:     cert_path,
      certificate_password: ENV['DIST_CERT_PASSWORD'],
      keychain_name:        "login.keychain-db"
    )

    profile_path = File.join(Dir.tmpdir, "profile.mobileprovision")
    File.binwrite(profile_path, Base64.decode64(ENV['PROVISION_PROFILE_BASE64']))

    build_app(
      workspace:      "ios/App/App.xcworkspace",
      scheme:         "App",
      export_method:  "app-store",
      export_options: {
        provisioningProfiles: { "app.dosuru" => profile_path }
      }
    )

    api_key = app_store_connect_api_key(
      key_id:      ENV['ASC_KEY_ID'],
      issuer_id:   ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_PRIVATE_KEY']
    )

    upload_to_app_store(
      api_key:                           api_key,
      skip_metadata:                     true,
      skip_screenshots:                  true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload to TestFlight only"
  lane :beta do
    setup_ci if ENV['CI']

    cert_path = File.join(Dir.tmpdir, "dist.p12")
    File.binwrite(cert_path, Base64.decode64(ENV['DIST_CERT_BASE64']))
    import_certificate(
      certificate_path:     cert_path,
      certificate_password: ENV['DIST_CERT_PASSWORD'],
      keychain_name:        "login.keychain-db"
    )

    profile_path = File.join(Dir.tmpdir, "profile.mobileprovision")
    File.binwrite(profile_path, Base64.decode64(ENV['PROVISION_PROFILE_BASE64']))

    build_app(
      workspace:      "ios/App/App.xcworkspace",
      scheme:         "App",
      export_method:  "app-store",
      export_options: {
        provisioningProfiles: { "app.dosuru" => profile_path }
      }
    )

    api_key = app_store_connect_api_key(
      key_id:      ENV['ASC_KEY_ID'],
      issuer_id:   ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_PRIVATE_KEY']
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
