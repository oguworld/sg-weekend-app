require 'base64'
require 'tmpdir'
require 'json'

default_platform(:ios)

platform :ios do
  desc "Build and submit to App Store review"
  lane :deploy do
    setup_ci if ENV['CI']

    cert_path = File.join(Dir.tmpdir, "dist.p12")
    File.binwrite(cert_path, Base64.decode64(ENV['DIST_CERT_BASE64']))
    import_certificate(
      certificate_path:     cert_path,
      certificate_password: ENV['DIST_CERT_PASSWORD'],
      keychain_name:        "fastlane_tmp_keychain",
      keychain_password:    ""
    )

    profile_path = File.join(Dir.tmpdir, "profile.mobileprovision")
    File.binwrite(profile_path, Base64.decode64(ENV['PROVISION_PROFILE_BASE64']))
    install_provisioning_profile(path: profile_path)

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id:               ENV['APPLE_TEAM_ID'],
      bundle_identifier:     "app.dosuru",
      code_sign_identity:    "Apple Distribution",
      profile_name:          "dosuru_appstore",
      path:                  "ios/App/App.xcodeproj"
    )

    build_app(
      workspace:      "ios/App/App.xcworkspace",
      scheme:         "App",
      export_method:  "app-store",
      xcargs:         "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']}",
      export_options: {
        teamID:               ENV['APPLE_TEAM_ID'],
        provisioningProfiles: { "app.dosuru" => "dosuru_appstore" }
      }
    )

    api_key = app_store_connect_api_key(
      key_id:      ENV['ASC_KEY_ID'],
      issuer_id:   ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_PRIVATE_KEY']
    )

    pkg           = JSON.parse(File.read('package.json'))
    app_version   = pkg['version'].split('.').first(2).join('.')  # "1.1.0" -> "1.1"
    release_notes = ENV['RELEASE_NOTES'] || "バグ修正とパフォーマンス改善"

    upload_to_app_store(
      api_key:                           api_key,
      app_identifier:                    "app.dosuru",
      app_version:                       app_version,
      submit_for_review:                 true,
      automatic_release:                 true,
      skip_metadata:                     true,
      skip_screenshots:                  true,
      precheck_include_in_app_purchases: false,
      force:                             true,
      release_notes:                     { "ja" => release_notes, "en-US" => release_notes }
    )
  end
end
